# ===========================================
# Klucze API do działania bota (Gemini)
# ===========================================
# Skopiuj ten plik jako .env.local i wklej swój klucz.
# Plik .env.local NIE commituj do repozytorium (jest w .gitignore).

# Google Gemini API (używane w /api/chat, /api/feedback i /api/tts)
# Akceptowane nazwy: GOOGLE_GENAI_API_KEY lub GOOGLE_GENERATIVE_AI_API_KEY
# Klucz weź z: https://aistudio.google.com/ → Get API key
# Ten sam klucz w .env.local jest używany także do głosu bota (TTS).
GOOGLE_GENAI_API_KEY=

# Naturalny głos bota (Neural2): wymaga klucza z Google CLOUD (nie AI Studio).
# 1. Wejdź: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# 2. Włącz "Cloud Text-to-Speech API", potem Utwórz dane logowania → Klucz API
# 3. Wklej tutaj – w .env.local ustaw: GOOGLE_TTS_API_KEY=twój_klucz
# Bez tego głos się nie odtworzy (klucz Gemini zwykle NIE działa do TTS).
GOOGLE_TTS_API_KEY=
